# Copy to .env.local for local dev, or set these as Vercel project env vars.

# Clerk (publishable key is safe to expose; secret key is server-only)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Django API base URL.
#   local:      http://127.0.0.1:8001
#   production: https://worldcup-api.onrender.com   (your Render URL)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
