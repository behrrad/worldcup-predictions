# Copy this file to .env and adjust the values.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
TIME_ZONE=Asia/Tehran

# --- Database (PostgreSQL / Supabase) ---
# Local Supabase (started with `supabase start`) defaults to port 54322:
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
# A plain local Postgres usually uses port 5432, e.g.:
# DATABASE_URL=postgres://worldcup:worldcup@127.0.0.1:5432/worldcup

# --- Clerk (only if you enable Clerk auth) ---
# CLERK_PUBLISHABLE_KEY=pk_test_xxx
# CLERK_SECRET_KEY=sk_test_xxx
# CLERK_FRONTEND_API_URL=https://your-app.clerk.accounts.dev
